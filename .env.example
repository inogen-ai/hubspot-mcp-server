# hubspot-mcp-server environment variables. Copy to .env and fill in what you need —
# or set these in your MCP client's config (the `env` block in
# claude_desktop_config.json, or `claude mcp add ... -e VAR=value`).
#
# Defaults shown are what the server uses when a variable is unset
# (see src/hubspot_mcp/settings.py).

# SECRET, required. A HubSpot Private App access token, sent as
# `Authorization: Bearer`. Create one in your HubSpot portal: Settings gear >
# Integrations > Private Apps > Create a private app > Scopes tab (select only
# the read scopes you need, e.g. crm.objects.contacts.read) > Create > copy the
# token — see the README's setup walkthrough. A free developer account/test
# portal is available at developers.hubspot.com.
#HUBSPOT_MCP_ACCESS_TOKEN=

# HubSpot API origin. Override for EU data residency, or to point the client
# at a local test double (a plain-http localhost override is allowed for
# testing only — HubSpot's real API is always https).
#HUBSPOT_MCP_BASE_URL=https://api.hubapi.com

# Default page size for list_records/search_records when their `limit`
# parameter is omitted, and the base for list_properties's output cap
# (item_limit x 10). Pass a per-call limit to list_records/search_records to
# override it for that call.
#HUBSPOT_MCP_ITEM_LIMIT=25

# HTTP timeout (seconds) per HubSpot request.
#HUBSPOT_MCP_TIMEOUT_SECONDS=30.0
